# Copy to `.env` for local development with `netlify dev`, and set the same
# variables in the Netlify dashboard (Site settings → Environment variables) for
# production. These keys are used ONLY by the serverless functions in
# netlify/functions/* — they are never shipped to the browser.

ALPHAVANTAGE_KEY=your-alpha-vantage-key
FINNHUB_KEY=your-finnhub-key
